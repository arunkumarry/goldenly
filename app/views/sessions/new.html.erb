<% content_for :title, "Sign in to Goldenly" %>
<main class="auth-page">
  <section class="workflow-card auth-card">
    <a class="brand" href="<%= root_path %>"><%= image_tag "goldenly-logo.png", class: "brand-logo", alt: "" %><span>Goldenly</span></a>
    <p class="eyebrow">WELCOME BACK</p>
    <h1>Sign in</h1>
    <p class="workflow-intro">Use your email address or phone number to receive a secure sign-in code.</p>
    <%= form_with url: session_path, class: "workflow-form" do |form| %>
      <div class="form-grid">
        <%= form.label :identifier, "Email address or phone number" %><%= form.text_field :identifier, required: true, autocomplete: "username", placeholder: "you@example.com or +14155552671" %>
      </div>
      <%= form.submit "Send sign-in code", class: "primary-button" %>
    <% end %>
    <p class="auth-switch">New to Goldenly? <%= link_to "Create an account", new_user_path %></p>
  </section>
</main>
