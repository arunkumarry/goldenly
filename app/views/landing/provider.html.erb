<% content_for :title, "Goldenly Provider Platform" %>

<main class="landing-page provider-preview">
  <header class="landing-nav"><%= link_to root_path, class: "landing-brand" do %><%= image_tag "goldenly-logo.png", alt: "", class: "landing-logo" %><span>Goldenly</span><% end %><div class="landing-nav-actions"><%= link_to "Back to home", root_path, class: "landing-login" %><%= link_to "Member sign up", new_user_path, class: "landing-button landing-button-small" %></div></header>
  <section class="provider-preview-hero"><p class="landing-kicker"><span></span> Goldenly Care Partner</p><h1>A trusted workspace for people who deliver care.</h1><p>Apply, complete verification, receive suitable service opportunities, coordinate confirmed visits, and track transparent earnings—all while protecting member information.</p><div class="provider-preview-list"><span>Human verification</span><span>Protected matching</span><span>Confirmed visits</span><span>Manual payouts</span></div><%= link_to current_care_partner_user ? "Open Care Partner workspace" : "Care Partner sign in", current_care_partner_user ? care_partners_root_path : new_care_partner_session_path, class: "landing-button" %><p class="provider-session-note">Care Partner sign-in is separate from your Goldenly member session.</p></section>
</main>
