<% content_for :title, "Admin overview · Goldenly" %>

<main class="admin-workspace">
  <%= render "admin/shared/sidebar" %>

  <section class="admin-content">
    <header class="admin-page-heading">
      <p class="eyebrow">GOLDENLY ADMIN</p>
      <h1>Care operations overview</h1>
      <p>Review provider applications and view the member records currently coordinated through Goldenly.</p>
    </header>

    <section class="admin-summary-grid" aria-label="Admin summary">
      <article><span>◉</span><div><small>Members</small><strong><%= @member_count %></strong></div></article>
      <article><span>✦</span><div><small>Awaiting review</small><strong><%= @provider_counts.fetch("submitted", 0) + @provider_counts.fetch("under_review", 0) %></strong></div></article>
      <article><span>✓</span><div><small>Active providers</small><strong><%= @provider_counts.fetch("active", 0) %></strong></div></article>
      <article><span>◷</span><div><small>Changes requested</small><strong><%= @provider_counts.fetch("changes_requested", 0) %></strong></div></article>
    </section>

    <div class="admin-columns">
      <section class="admin-panel">
        <div class="admin-panel-heading">
          <div><p class="eyebrow">PROVIDER REVIEW</p><h2>New applications</h2></div>
          <%= link_to "View all →", admin_providers_path %>
        </div>
        <% @review_queue.each do |provider| %>
          <%= link_to admin_provider_path(provider), class: "admin-list-row" do %>
            <div class="avatar small"><%= (provider.profile&.display_name || provider.user.full_name).first %></div>
            <div><strong><%= provider.profile&.display_name || provider.user.full_name %></strong><small><%= provider.profile&.broad_location.presence || provider.user.country || "Location not supplied" %> · <%= provider.submitted_at ? "submitted #{provider.submitted_at.to_date.to_fs(:long)}" : "application in progress" %></small></div>
            <span class="status-pill <%= provider.under_review? ? "blue" : "" %>"><%= provider.application_status.humanize %></span>
            <b>→</b>
          <% end %>
        <% end %>
        <% if @review_queue.empty? %><p class="empty-state">There are no provider applications awaiting review.</p><% end %>
      </section>

      <section class="admin-panel">
        <div class="admin-panel-heading">
          <div><p class="eyebrow">MEMBERS</p><h2>Recently added</h2></div>
          <%= link_to "View all →", admin_members_path %>
        </div>
        <% @recent_members.each do |member| %>
          <%= link_to admin_member_path(member), class: "admin-list-row" do %>
            <div class="avatar small"><%= member.full_name.first %></div>
            <div><strong><%= member.full_name %></strong><small><%= member.country || "Country not supplied" %> · <%= pluralize(member.owned_care_profiles.size, "care profile") %></small></div>
            <b>→</b>
          <% end %>
        <% end %>
        <% if @recent_members.empty? %><p class="empty-state">No member records yet.</p><% end %>
      </section>
    </div>
  </section>
</main>
