<% content_for :title, "Members · Goldenly Admin" %>

<main class="admin-workspace">
  <%= render "admin/shared/sidebar" %>

  <section class="admin-content">
    <header class="admin-page-heading">
      <p class="eyebrow">MEMBERS</p>
      <h1>Member records</h1>
      <p>View account details and the care profiles each member coordinates. This panel is read-only for now.</p>
    </header>

    <section class="admin-panel admin-table-panel">
      <div class="admin-panel-heading"><div><p class="eyebrow">ALL MEMBERS</p><h2><%= pluralize(@members.size, "member") %></h2></div></div>
      <div class="admin-table" role="table">
        <div class="admin-table-row admin-table-heading" role="row"><span>Member</span><span>Contact</span><span>Location</span><span>Care profiles</span><span>Joined</span><span></span></div>
        <% @members.each do |member| %>
          <%= link_to admin_member_path(member), class: "admin-table-row", role: "row" do %>
            <span><strong><%= member.full_name %></strong><small><%= member.platform_role.humanize %></small></span>
            <span><%= member.identifier || "—" %></span>
            <span><%= [member.city, member.region, member.country].compact_blank.to_sentence.presence || "—" %></span>
            <span><%= member.owned_care_profiles.size %></span>
            <span><%= member.created_at.to_date.to_fs(:long) %></span>
            <b>→</b>
          <% end %>
        <% end %>
      </div>
      <% if @members.empty? %><p class="empty-state">No member records yet.</p><% end %>
    </section>
  </section>
</main>
