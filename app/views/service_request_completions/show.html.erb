<% content_for :title, "Confirm service · Goldenly" %>
<main class="dashboard"><%= render "shared/sidebar" %><section class="content"><div class="workflow-page"><%= link_to "← Back to dashboard", dashboard_path, class: "back-link" %><section class="workflow-card completion-card"><p class="eyebrow">SERVICE CONFIRMATION</p><h1>Was this service completed?</h1><p class="workflow-intro"><strong><%= @service_request.service_catalog.name %></strong> was submitted by <%= @assignment.care_partner.profile&.display_name || @assignment.care_partner.user.full_name %> at <%= @assignment.completed_at&.strftime("%-I:%M %p on %-d %B") %>. Confirm only if the service summary is accurate.</p><% if @assignment.visit_submission %><div class="application-readiness"><strong>Service summary</strong><p><%= @assignment.visit_submission.notes.presence || "No additional notes were submitted." %></p><% if @assignment.visit_submission.follow_up_needed.present? %><p><strong>Follow-up:</strong> <%= @assignment.visit_submission.follow_up_needed %></p><% end %></div><% end %><%= form_with url: service_request_completion_path(@service_request), method: :patch, scope: :completion, class: "workflow-form" do |form| %><%= form.hidden_field :outcome, value: "confirm" %><%= form.label :code, "Confirmation code (optional if you are confirming in Goldenly)" %><%= form.text_field :code, inputmode: "numeric", placeholder: "Code from your Goldenly app" %><%= form.submit "Confirm service", class: "primary-button" %><% end %><%= form_with url: service_request_completion_path(@service_request), method: :patch, scope: :completion, class: "workflow-form dispute-form" do |form| %><%= form.hidden_field :outcome, value: "dispute" %><%= form.label :reason, "Something needs attention?" %><%= form.text_area :reason, rows: 3, placeholder: "Tell Goldenly operations what needs review" %><%= form.submit "Dispute service", class: "text-button" %><% end %></section></div></section></main>
