<% content_for :title, "Care profile · Goldenly" %>
<main class="dashboard"><%= render "shared/sidebar" %><section class="content"><div class="workflow-page">
  <%= link_to "← Back to dashboard", dashboard_path, class: "back-link" %>
  <section class="workflow-card"><p class="eyebrow">CARE PROFILE</p><h1><%= @care_profile.full_name %></h1><p class="workflow-intro"><%= @care_profile.state.humanize %> profile. Details are kept separate from every other person’s care.</p><%= render "shared/errors", record: @care_profile %>
    <%= form_with model: @care_profile, class: "workflow-form" do |form| %><div class="form-grid"><%= form.label :full_name %><%= form.text_field :full_name, required: true %><div data-controller="phone-input"><%= form.label :phone_number %><div class="phone-number-input"><%= select_tag :phone_country_code, options_for_select(ApplicationHelper::CALLING_CODES, "+91"), aria: { label: "Country calling code" }, data: { phone_input_target: "code", action: "change->phone-input#sync" } %><%= form.telephone_field :phone_number, placeholder: "Phone number", inputmode: "tel", data: { phone_input_target: "phone", action: "input->phone-input#sync" } %></div></div><%= form.label :preferred_language %><%= form.select :preferred_language, ApplicationHelper::SUPPORTED_LANGUAGES %><%= render "shared/address_fields", form: form %><%= form.label :mobility_needs %><%= form.text_field :mobility_needs %></div><%= form.submit "Save care profile", class: "primary-button" %><% end %>
  </section>
</div></section></main>
