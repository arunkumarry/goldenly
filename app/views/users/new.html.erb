<% content_for :title, "Create your Goldenly account" %>
<main class="auth-page">
  <section class="workflow-card auth-card">
    <a class="brand" href="<%= root_path %>"><%= image_tag "goldenly-logo.png", class: "brand-logo", alt: "" %><span>Goldenly</span></a>
    <p class="eyebrow">GET STARTED</p>
    <h1>Create your account</h1>
    <p class="workflow-intro">Set up your account and a private care profile, then verify the email or phone number you use.</p>
    <%= render "shared/errors", record: @user %><%= render "shared/errors", record: @care_profile %>
    <%= form_with url: users_path, class: "workflow-form", data: { controller: "onboarding identifier", action: "submit->identifier#prepare" } do |form| %>
      <div class="form-grid">
        <%= fields_for :user, @user do |user_form| %>
          <%= user_form.label :full_name, "Your name" %><%= user_form.text_field :full_name, required: true, autocomplete: "name" %>
          <%= render "shared/address_fields", form: user_form %>
        <% end %>
        <%= render "shared/identifier_fields" %>
        <hr class="form-divider">
        <p class="form-section-title">First care profile</p>
        <%= label_tag :setup_for, "Who is this profile for?" %><%= select_tag :setup_for, options_for_select([["Myself", "self"], ["Someone else", "someone_else"]]), data: { onboarding_target: "choice", action: "change->onboarding#toggle" } %>
        <%= fields_for :care_profile, @care_profile do |care_profile_form| %>
          <%= care_profile_form.label :full_name, "Person’s name" %><%= care_profile_form.text_field :full_name, required: true %>
          <%= care_profile_form.label :phone_number, "Person’s phone number (optional)" %><%= care_profile_form.telephone_field :phone_number %>
          <%= care_profile_form.label :preferred_language, "Preferred language" %><%= care_profile_form.select :preferred_language, ApplicationHelper::SUPPORTED_LANGUAGES, required: true %>
          <%= render "shared/address_fields", form: care_profile_form %>
        <% end %>
        <div data-onboarding-target="coordinatorFields"><%= label_tag :relationship_to_person, "Relationship to this person" %><%= select_tag :relationship_to_person, options_for_select([["Family member", "family"], ["Spouse or partner", "spouse"], ["Someone I support", "supported"]]) %><%= label_tag :consent_basis, "Consent or basis for setup" %><%= text_field_tag :consent_basis, nil, placeholder: "They asked me to coordinate their care" %></div>
      </div>
      <%= form.submit "Send verification code", class: "primary-button" %>
    <% end %>
    <p class="auth-switch">Already have an account? <%= link_to "Sign in", new_session_path %></p>
  </section>
</main>
