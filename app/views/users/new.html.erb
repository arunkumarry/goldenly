<% content_for :title, "Create your Goldenly account" %>
<main class="auth-page">
  <section class="workflow-card auth-card">
    <a class="brand" href="<%= root_path %>"><%= image_tag "goldenly-logo.png", class: "brand-logo", alt: "" %><span>Goldenly</span></a>
    <p class="eyebrow">GET STARTED</p>
    <h1>Create your account</h1>
    <p class="workflow-intro">Set up your account and a private care profile, then verify the email or phone number you use.</p>
    <%= render "shared/errors", record: @user %><%= render "shared/errors", record: @care_profile %>
    <%= form_with url: users_path, class: "workflow-form", data: { controller: "onboarding" } do |form| %>
      <div class="form-grid">
        <%= label_tag "user_full_name", "Your name" %><%= text_field_tag "user[full_name]", @user.full_name, id: "user_full_name", required: true, autocomplete: "name" %>
        <%= label_tag :identifier, "Email address or phone number" %><%= text_field_tag :identifier, nil, id: "identifier", required: true, autocomplete: "username", placeholder: "you@example.com or +14155552671" %>
        <%= label_tag "user_country", "Your country" %><%= text_field_tag "user[country]", @user.country, id: "user_country", required: true, autocomplete: "country-name" %>
        <%= label_tag "user_location", "Your city, state, or region" %><%= text_field_tag "user[location]", @user.location, id: "user_location" %>
        <hr class="form-divider">
        <p class="form-section-title">First care profile</p>
        <%= label_tag :setup_for, "Who is this profile for?" %><%= select_tag :setup_for, options_for_select([["Myself", "self"], ["Someone else", "someone_else"]]), data: { onboarding_target: "choice", action: "change->onboarding#toggle" } %>
        <%= label_tag "care_profile_full_name", "Person’s name" %><%= text_field_tag "care_profile[full_name]", @care_profile.full_name, id: "care_profile_full_name", required: true %>
        <%= label_tag "care_profile_phone_number", "Person’s phone number (optional)" %><%= telephone_field_tag "care_profile[phone_number]", @care_profile.phone_number, id: "care_profile_phone_number" %>
        <%= label_tag "care_profile_preferred_language", "Preferred language" %><%= select_tag "care_profile[preferred_language]", options_for_select(["English", "Telugu"], @care_profile.preferred_language), id: "care_profile_preferred_language", required: true %>
        <%= label_tag "care_profile_country", "Person’s country" %><%= text_field_tag "care_profile[country]", @care_profile.country, id: "care_profile_country", required: true, autocomplete: "country-name" %>
        <%= label_tag "care_profile_location", "Person’s city, state, or region" %><%= text_field_tag "care_profile[location]", @care_profile.location, id: "care_profile_location" %>
        <div data-onboarding-target="coordinatorFields"><%= label_tag :relationship_to_person, "Relationship to this person" %><%= select_tag :relationship_to_person, options_for_select([["Family member", "family"], ["Spouse or partner", "spouse"], ["Someone I support", "supported"]]) %><%= label_tag :consent_basis, "Consent or basis for setup" %><%= text_field_tag :consent_basis, nil, placeholder: "They asked me to coordinate their care" %></div>
      </div>
      <%= form.submit "Send verification code", class: "primary-button" %>
    <% end %>
    <p class="auth-switch">Already have an account? <%= link_to "Sign in", new_session_path %></p>
  </section>
</main>
