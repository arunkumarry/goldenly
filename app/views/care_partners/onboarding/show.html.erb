<% content_for :title, "Care Partner application · Goldenly" %>
<main class="care-partner-workspace">
  <%= render "care_partners/shared/sidebar" %>
  <section class="care-partner-content onboarding-content">
    <%= link_to "← Back to overview", care_partners_root_path, class: "back-link" %>
    <header class="care-partner-page-heading"><p class="eyebrow">CARE PARTNER APPLICATION</p><h1>Build a profile members can trust.</h1><p>Your draft is saved as you go. Goldenly’s human review team makes every approval decision.</p></header>
    <nav class="onboarding-steps" aria-label="Application progress">
      <% [[1, "Your details"], [2, "Identity"], [3, "Services"], [4, "Review"]].each do |number, label| %><%= link_to care_partners_onboarding_path(step: number), class: "#{@step == number ? 'active' : ''} #{@step > number ? 'complete' : ''}" do %><b><%= number %></b><span><%= label %></span><% end %><% end %>
    </nav>
    <section class="care-partner-form-card">
      <%= render "shared/errors", record: @profile %>
      <% if @step == 1 %>
        <p class="eyebrow">STEP 1 OF 4</p><h2>Tell us about yourself</h2><p>We use these details for verification and safe service coordination.</p>
        <%= form_with url: care_partners_onboarding_path(step: @step), method: :patch, class: "care-partner-form", html: { multipart: true } do %>
          <div class="care-partner-form-grid two">
            <div><%= label_tag "care_partner_profile_legal_name", "Legal name" %><%= text_field_tag "care_partner_profile[legal_name]", @profile.legal_name, required: true %></div>
            <div><%= label_tag "care_partner_profile_display_name", "Display name" %><%= text_field_tag "care_partner_profile[display_name]", @profile.display_name, required: true %></div>
            <div><%= label_tag "care_partner_profile_date_of_birth", "Date of birth" %><%= date_field_tag "care_partner_profile[date_of_birth]", @profile.date_of_birth, required: true %></div>
            <div class="profile-photo-field"><%= label_tag "care_partner_profile_profile_photo", "Profile photo" %><%= file_field_tag "care_partner_profile[profile_photo]", accept: "image/jpeg,image/png,image/webp", required: !@profile.profile_photo.attached? %><small>JPG, PNG, or WebP · up to 5 MB</small><% if @profile.profile_photo.attached? %><%= image_tag @profile.profile_photo, class: "profile-photo-preview", alt: "Current profile photo" %><% end %></div>
            <div class="full"><%= label_tag "care_partner_profile_address", "Residential address" %><%= text_field_tag "care_partner_profile[address]", @profile.address, placeholder: "Street address", required: true %></div>
            <div><%= label_tag "care_partner_profile_city", "City" %><%= text_field_tag "care_partner_profile[city]", @profile.city, required: true %></div>
            <div><%= label_tag "care_partner_profile_region", "State / region" %><%= text_field_tag "care_partner_profile[region]", @profile.region, required: true %></div>
            <div><%= label_tag "care_partner_profile_country", "Country" %><%= text_field_tag "care_partner_profile[country]", @profile.country, placeholder: "India or United States", required: true %></div>
            <div><%= label_tag "care_partner_profile_country_code", "Country code" %><%= text_field_tag "care_partner_profile[country_code]", @profile.country_code, maxlength: 2, placeholder: "IN or US", required: true %></div>
            <div><%= label_tag "care_partner_profile_postal_code", "Postal code" %><%= text_field_tag "care_partner_profile[postal_code]", @profile.postal_code %></div>
            <div><%= label_tag "care_partner_profile_languages_text", "Languages (comma separated)" %><%= text_field_tag "care_partner_profile[languages_text]", @profile.languages.join(", "), placeholder: "English, Telugu", required: true %></div>
            <div><%= label_tag "care_partner_profile_emergency_contact_phone", "Emergency contact phone" %><%= telephone_field_tag "care_partner_profile[emergency_contact_phone]", @profile.emergency_contact_phone, required: true %></div>
            <div class="full"><%= label_tag "care_partner_profile_emergency_contact_name", "Emergency contact name" %><%= text_field_tag "care_partner_profile[emergency_contact_name]", @profile.emergency_contact_name, required: true %></div>
          </div>
          <%= submit_tag "Save and continue", class: "primary-button" %>
        <% end %>
      <% elsif @step == 2 %>
        <p class="eyebrow">STEP 2 OF 4</p><h2>Verify your identity</h2><p>Use a redacted reference where possible. Goldenly does not ask you to place raw sensitive identity numbers in notes.</p>
        <div class="evidence-list"><% @account.verification_documents.each do |document| %><article><div><strong><%= document.document_type %></strong><small><%= document.country_code %> · <%= document.verification_status.humanize %></small></div><%= button_to "Remove", care_partners_document_path(document), method: :delete, class: "text-button" %></article><% end %></div>
        <%= form_with model: @document, url: care_partners_documents_path, class: "care-partner-form compact-form" do |form| %><div class="care-partner-form-grid two"><div><%= form.label :document_type, "Document type" %><%= form.select :document_type, [["Government photo ID", "government_photo_id"], ["Passport", "passport"], ["Driving licence", "driving_licence"], ["India identity document", "india_identity_document"]], prompt: "Choose" %></div><div><%= form.label :country_code, "Country code" %><%= form.text_field :country_code, maxlength: 2, value: @profile.country_code %></div><div><%= form.label :redacted_reference, "Redacted reference" %><%= form.text_field :redacted_reference, placeholder: "Last four digits or reference" %></div><div><%= form.label :expires_on, "Expiry date (if any)" %><%= form.date_field :expires_on %></div><div class="full"><%= form.label :file_reference, "Secure document link / capture reference" %><%= form.url_field :file_reference, placeholder: "https://…" %></div></div><%= form.submit "Save identity document", class: "secondary-button" %><% end %>
        <%= link_to "Continue to services →", care_partners_onboarding_path(step: 3), class: "primary-button" %>
      <% elsif @step == 3 %>
        <p class="eyebrow">STEP 3 OF 4</p><h2>Choose your services and scope</h2><p>Clinical services remain unavailable until a human reviewer verifies your current professional credential.</p>
        <div class="evidence-list"><% @account.care_partner_services.includes(:service_catalog).each do |service| %><article><div><strong><%= service.service_catalog.name %></strong><small><%= service.status.humanize %> · <%= service.service_zones.presence&.to_sentence || "Any selected zone" %></small></div><%= button_to "Remove", care_partners_service_path(service), method: :delete, class: "text-button" %></article><% end %></div>
        <%= form_with model: @care_partner_service, url: care_partners_services_path, class: "care-partner-form compact-form" do |form| %><div class="care-partner-form-grid two"><div><%= form.label :service_catalog_id, "Goldenly service" %><%= form.collection_select :service_catalog_id, ServiceCatalog.available, :id, :name, { prompt: "Choose a service" } %></div><div><%= form.label :travel_radius_km, "Travel radius (km)" %><%= form.number_field :travel_radius_km, min: 1, max: 200 %></div><div><%= label_tag "care_partner_service_service_zones_text", "Cities, states, or countries" %><%= text_field_tag "care_partner_service[service_zones_text]", nil, placeholder: "Hyderabad, Telangana" %></div><div><%= label_tag "care_partner_service_languages_text", "Languages" %><%= text_field_tag "care_partner_service[languages_text]", @profile.languages.join(", ") %></div><div class="full"><%= label_tag "care_partner_service_available_days_text", "Available days (comma separated)" %><%= text_field_tag "care_partner_service[available_days_text]", nil, placeholder: "Monday, Tuesday, Wednesday" %></div></div><%= form.submit "Add service preference", class: "secondary-button" %><% end %>
        <div class="evidence-list"><% @account.credentials.includes(:service_catalog).each do |credential| %><article><div><strong><%= credential.credential_type %></strong><small><%= credential.service_catalog&.name || "General" %> · <%= credential.verification_status.humanize %></small></div><%= button_to "Remove", care_partners_credential_path(credential), method: :delete, class: "text-button" %></article><% end %></div>
        <%= form_with model: @credential, url: care_partners_credentials_path, class: "care-partner-form compact-form" do |form| %><div class="care-partner-form-grid two"><div><%= form.label :service_catalog_id, "Service scope (optional)" %><%= form.collection_select :service_catalog_id, ServiceCatalog.available, :id, :name, { include_blank: "General" } %></div><div><%= form.label :credential_type, "Credential or certification" %><%= form.text_field :credential_type, placeholder: "Licence or training certificate" %></div><div><%= form.label :issuer, "Issuing body" %><%= form.text_field :issuer %></div><div><%= form.label :credential_reference, "Reference (redacted where needed)" %><%= form.text_field :credential_reference %></div><div><%= form.label :expires_on, "Expiry date" %><%= form.date_field :expires_on %></div><div><%= form.label :file_reference, "Secure evidence link" %><%= form.url_field :file_reference %></div></div><%= form.submit "Save credential", class: "secondary-button" %><% end %>
        <%= form_with url: care_partners_onboarding_path(step: @step), method: :patch, class: "care-partner-form compact-form" do %><div class="care-partner-form-grid"><%= label_tag "care_partner_profile_experience_summary", "Experience summary" %><%= text_area_tag "care_partner_profile[experience_summary]", @profile.experience_summary, rows: 4, placeholder: "Your service experience and training" %><%= label_tag "care_partner_profile_introduction_video_url", "30–90 second introduction video link" %><%= url_field_tag "care_partner_profile[introduction_video_url]", @profile.introduction_video_url, placeholder: "https://…", required: true %></div><%= submit_tag "Save services and continue", class: "primary-button" %><% end %>
      <% else %>
        <p class="eyebrow">STEP 4 OF 4</p><h2>Review and submit</h2><p>Once submitted, a Goldenly moderator reviews your evidence. AI may flag missing information, but never makes the decision.</p>
        <div class="application-readiness"><strong>Before you submit</strong><% if @account.onboarding_missing_fields.any? %><ul><% @account.onboarding_missing_fields.each do |field| %><li><%= field.humanize %></li><% end %></ul><% else %><p>Everything required for review is present.</p><% end %></div>
        <%= form_with url: care_partners_onboarding_path(step: @step), method: :patch, class: "care-partner-form" do %><div class="care-partner-form-grid"><%= label_tag "care_partner_account_payout_method_summary", "Payout method summary" %><%= text_field_tag "care_partner_account[payout_method_summary]", @account.payout_method_summary, placeholder: "Verified bank account / payout method" %><label class="declaration"><%= check_box_tag "declarations[terms]", "1", @account.terms_accepted_at.present? %> I accept the Care Partner terms (version 2026-07).</label><label class="declaration"><%= check_box_tag "declarations[privacy]", "1", @account.privacy_accepted_at.present? %> I consent to identity, location, and payout processing for service coordination.</label><label class="declaration"><%= check_box_tag "declarations[code_of_conduct]", "1", @account.code_of_conduct_accepted_at.present? %> I accept Goldenly’s code of conduct.</label><label class="declaration"><%= check_box_tag "declarations[service_standards]", "1", @account.service_standards_accepted_at.present? %> I accept the service standards and my permitted scope.</label></div><%= submit_tag "Save review details", class: "secondary-button" %><% end %>
        <%= button_to "Submit for human review", submit_care_partners_onboarding_path, method: :post, class: "primary-button", disabled: !@account.ready_to_submit? %>
      <% end %>
    </section>
  </section>
</main>
