<% content_for :title, "Services & availability · Goldenly" %>
<main class="care-partner-workspace">
  <%= render "care_partners/shared/sidebar" %>
  <section class="care-partner-content">
    <header class="care-partner-page-heading"><p class="eyebrow">SERVICE SCOPE</p><h1>Services and availability</h1><p>Goldenly only matches you to services that have been approved for your profile. Pause new work at any time from the overview.</p></header>
    <div class="care-partner-two-column-page">
      <section class="care-partner-panel">
        <div class="care-partner-panel-heading"><div><p class="eyebrow">YOUR SERVICES</p><h2>Approved scope</h2></div></div>
        <% @care_partner_services.each do |service| %>
          <article class="scope-item"><div><strong><%= service.service_catalog.name %></strong><small><%= service.status.humanize %> · <%= service.service_catalog.clinical? ? "Clinical credential required" : "Non-clinical service" %></small><p><%= service.service_zones.presence&.to_sentence || "No zone limits supplied" %> · <%= service.languages.presence&.to_sentence || "Languages not supplied" %></p></div><%= button_to "Remove", care_partners_service_path(service), method: :delete, class: "text-button" %></article>
        <% end %>
        <% if @care_partner_services.empty? %><p class="empty-state">Choose services in the form to begin. They are inactive until a moderator approves them.</p><% end %>
      </section>
      <section class="care-partner-form-card">
        <p class="eyebrow">ADD SERVICE</p><h2>Where can you help?</h2><p>Use broad service zones. Specific member details are never shown before a successful match.</p>
        <%= render "shared/errors", record: @care_partner_service %>
        <%= form_with model: @care_partner_service, url: care_partners_services_path, class: "care-partner-form" do |form| %>
          <div class="care-partner-form-grid"><%= form.label :service_catalog_id, "Goldenly service" %><%= form.collection_select :service_catalog_id, ServiceCatalog.available, :id, :name, { prompt: "Choose a service" }, required: true %><%= label_tag "care_partner_service_service_zones_text", "Service zones" %><%= text_field_tag "care_partner_service[service_zones_text]", nil, placeholder: "Hyderabad, Telangana, India" %><%= label_tag "care_partner_service_languages_text", "Languages" %><%= text_field_tag "care_partner_service[languages_text]", current_care_partner_account.profile.languages.join(", "), placeholder: "English, Telugu" %><%= label_tag "care_partner_service_available_days_text", "Available days" %><%= text_field_tag "care_partner_service[available_days_text]", nil, placeholder: "Monday, Tuesday" %><%= form.label :travel_radius_km, "Travel radius (km)" %><%= form.number_field :travel_radius_km, min: 1, max: 200 %><%= form.label :max_concurrent_visits, "Maximum concurrent visits" %><%= form.number_field :max_concurrent_visits, min: 1, max: 20, value: 1 %></div>
          <%= form.submit "Save service preference", class: "primary-button" %>
        <% end %>
      </section>
    </div>
  </section>
</main>
