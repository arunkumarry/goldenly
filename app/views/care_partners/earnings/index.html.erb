<% content_for :title, "Earnings · Goldenly" %>
<main class="care-partner-workspace">
  <%= render "care_partners/shared/sidebar" %>
  <section class="care-partner-content">
    <header class="care-partner-page-heading"><p class="eyebrow">EARNINGS</p><h1>Clear earnings, manual payouts</h1><p>A service only becomes available for a manual Goldenly payout after the member or coordinator confirms it.</p></header>
    <section class="care-partner-summary-grid earnings-summary"><article><span>◉</span><div><small>Estimated</small><strong><%= EarningsLedgerEntry::MoneyAmount.new(@totals.fetch("estimated", 0), @entries.first&.currency || "USD") %></strong></div></article><article><span>◷</span><div><small>Pending confirmation</small><strong><%= EarningsLedgerEntry::MoneyAmount.new(@totals.fetch("pending_confirmation", 0), @entries.first&.currency || "USD") %></strong></div></article><article><span>✓</span><div><small>Available</small><strong><%= EarningsLedgerEntry::MoneyAmount.new(@totals.fetch("available", 0), @entries.first&.currency || "USD") %></strong></div></article><article><span>!</span><div><small>On hold</small><strong><%= EarningsLedgerEntry::MoneyAmount.new(@totals.fetch("on_hold", 0), @entries.first&.currency || "USD") %></strong></div></article></section>
    <section class="care-partner-panel"><div class="care-partner-panel-heading"><div><p class="eyebrow">LEDGER</p><h2>Service earnings</h2></div><span class="manual-pill">Manual payout only</span></div><% @entries.each do |entry| %><article class="ledger-item"><div><strong><%= entry.service_assignment.service_request.service_catalog.name %></strong><small><%= entry.created_at.to_date.to_fs(:long) %> · Goldenly fee <%= EarningsLedgerEntry::MoneyAmount.new(entry.goldenly_fee_cents, entry.currency) %></small></div><span class="status-pill <%= entry.available? ? 'success' : '' %>"><%= entry.status.humanize %></span><b><%= entry.amount %></b></article><% end %><% if @entries.empty? %><p class="empty-state">Accepted requests create an estimated ledger entry. No earnings are payable before confirmed completion.</p><% end %></section>
  </section>
</main>
