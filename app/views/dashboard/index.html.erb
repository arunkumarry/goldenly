<% content_for :title, "Goldenly · Care Dashboard" %>

<main class="dashboard">
  <%= render "shared/sidebar" %>
  <section class="content">
    <header class="topbar">
      <div>
        <p class="eyebrow">CARE DASHBOARD</p>
        <h1>Hello, <%= current_user.full_name.split.first %> <span aria-hidden="true">☀</span></h1>
        <p class="active-profile-banner"><%= coordinator_mode? ? "Viewing #{@care_profile.full_name}’s care. Your actions apply only to this profile." : "Viewing your care." %></p>
      </div>
      <div class="top-actions"><%= link_to "View calendar", calendar_path, class: "outline-button" %><div class="avatar"><%= current_user.full_name.first %></div></div>
    </header>

    <section class="hero-card">
      <div class="hero-copy">
        <span class="hero-kicker">Your care, at a glance</span>
        <h2><%= @today_reminders.any? ? "Your plan is ready for today." : "Start building your care plan." %></h2>
        <p><%= @today_reminders.any? ? "#{@today_reminders.count} reminder#{'s' if @today_reminders.count != 1} scheduled today." : "Add a reminder, request a service, or ask Goldenly for help." %></p>
        <%= link_to "Open calendar →", calendar_path, class: "text-link" %>
      </div>
      <div class="hero-art" aria-hidden="true"><div class="sun"></div><div class="plant"><i></i><i></i><i></i></div><div class="care-figure">♡</div></div>
    </section>

    <section class="summary-grid" aria-label="Care overview">
      <article class="summary-card"><span class="card-icon amber">⌁</span><div><p>Today’s reminders</p><strong><%= @today_reminders.count %></strong><small><%= @today_reminders.where(status: "completed").count %> completed</small></div></article>
      <article class="summary-card"><span class="card-icon sky">▣</span><div><p>Active requests</p><strong><%= @service_requests.reject(&:completed?).count %></strong><small>Profile-specific support requests</small></div></article>
      <article class="summary-card"><span class="card-icon green">♧</span><div><p>People with access</p><strong><%= @circle_links.count %></strong><small>Trusted-circle connections</small></div></article>
      <article class="summary-card"><span class="card-icon">▦</span><div><p>Upcoming reminders</p><strong><%= @reminders.count %></strong><small><%= link_to "View calendar", calendar_path %></small></div></article>
    </section>

    <div class="dashboard-columns">
      <section class="panel schedule-panel" id="today">
        <div class="panel-heading"><div><p class="eyebrow">SCHEDULE</p><h2>Upcoming reminders</h2></div><%= link_to "Calendar →", calendar_path %></div>
        <div class="schedule-list">
          <% @reminders.each_with_index do |reminder, index| %><%= render "reminders/reminder", reminder: reminder, index: index %><% end %>
          <% if @reminders.empty? %><p class="empty-state">No reminders yet. <%= link_to "Create the first reminder", new_reminder_path %>.</p><% end %>
        </div>
      </section>

      <aside class="quick-panel">
        <section class="panel quick-actions">
          <div class="panel-heading"><div><p class="eyebrow">QUICK ACTIONS</p><h2>What do you need?</h2></div></div>
          <%= link_to new_service_request_path do %>✦ <span>Request a service</span><b>→</b><% end %>
          <button type="button" data-agent-open>◉ <span>Talk to Goldenly</span><b>→</b></button>
          <%= link_to edit_care_profile_path(@care_profile) do %>▤ <span>Edit care profile</span><b>→</b><% end %>
        </section>
        <section class="assistant-card" id="assistant" data-care-agent data-message-url="<%= assistant_messages_path %>" data-confirm-url="<%= confirm_assistant_action_path %>">
          <div class="assistant-orb">✦</div><div><p>Goldenly AI</p><strong>“How can I help today?”</strong></div>
          <button type="button" class="outline-button" data-agent-open>Talk now</button>
          <dialog class="agent-dialog" aria-label="Talk to Goldenly">
            <div class="agent-dialog-header"><div><p class="eyebrow">GOLDENLY VOICE ASSISTANT</p><h2>How can I help?</h2></div><button type="button" class="dialog-close" data-agent-close aria-label="Close">×</button></div>
            <p class="agent-intro">Ask about this person’s recorded care plan, reminders, services, or urgent help. English and Telugu are supported.</p>
            <label class="agent-label" for="agent-language">Language</label><select id="agent-language" data-agent-language><option>English</option><option>Telugu</option></select>
            <label class="agent-label" for="agent-message">What do you need?</label><textarea id="agent-message" data-agent-input placeholder="For example: when is my next reminder?"></textarea>
            <div class="agent-actions"><button type="button" class="agent-secondary" data-agent-microphone>Speak</button><button type="button" class="agent-primary" data-agent-submit>Ask Goldenly</button></div>
            <p class="agent-reply" data-agent-reply hidden aria-live="polite"></p>
            <section class="agent-proposal" data-agent-proposal hidden aria-live="polite"><strong data-proposal-title></strong><p data-proposal-summary></p><p data-proposal-confirmation></p><label class="agent-location"><input type="checkbox" data-agent-share-location> Include my saved location with an emergency alert</label><button type="button" class="agent-primary" data-agent-confirm>Confirm action</button></section>
            <p class="agent-safety">Goldenly does not diagnose, prescribe, or change medication. For immediate danger, call local emergency services.</p>
          </dialog>
        </section>
      </aside>
    </div>

    <div class="lower-grid">
      <section class="panel timeline-panel">
        <div class="panel-heading"><div><p class="eyebrow">CARE ACTIVITY</p><h2>Recent updates</h2></div></div>
        <% @audit_events.each do |event| %><article class="event"><span class="event-icon">⌁</span><div><small><%= event.occurred_at.to_fs(:short) %></small><strong><%= event.action.humanize %></strong></div></article><% end %>
        <% if @audit_events.empty? %><p class="empty-state">Activity will appear here as care is coordinated.</p><% end %>
      </section>
      <section class="panel circle-panel">
        <div class="panel-heading"><div><p class="eyebrow">TRUSTED CIRCLE</p><h2>People with access</h2></div><%= link_to "Manage →", trusted_circle_path %></div>
        <% @circle_links.each do |link| %><article class="contact"><div class="avatar small"><%= link.user.full_name.first %></div><div><strong><%= link.user.full_name %></strong><p><%= link.relationship_to_person.humanize %></p></div></article><% end %>
        <% if @circle_links.empty? %><p class="empty-state"><%= link_to "Invite someone to the trusted circle", trusted_circle_path %>.</p><% end %>
      </section>
    </div>
  </section>
</main>
