<% content_for :title, "Manual payouts · Goldenly" %>
<main class="care-partner-workspace"><%= render "care_partners/shared/sidebar" %><section class="care-partner-content"><header class="care-partner-page-heading"><p class="eyebrow">OPERATIONS & FINANCE</p><h1>Manual payout review</h1><p>Only confirmed services are available for manual payout processing. Every status change creates an audit record.</p></header><section class="care-partner-panel"><% @entries.each do |entry| %><article class="payout-row"><div><strong><%= entry.care_partner.profile&.display_name || entry.care_partner.user.full_name %></strong><small><%= entry.service_assignment.service_request.service_catalog.name %> · <%= entry.amount %> · <%= entry.status.humanize %></small></div><% if current_user.can_manage_care_partner_payouts? %><%= form_with url: moderation_earning_path(entry), method: :patch, scope: :earnings_ledger_entry, class: "inline-payout-form" do |form| %><%= form.select :status, [["On hold", "on_hold"], ["Processing", "payout_processing"], ["Paid", "paid"], ["Failed", "failed"]], selected: entry.status %><%= form.text_field :payout_reference, placeholder: "Transfer reference" %><%= form.submit "Update", class: "secondary-button" %><% end %><% else %><span class="status-pill"><%= entry.status.humanize %></span><% end %></article><% end %><% if @entries.empty? %><p class="empty-state">There are no earnings ledger entries yet.</p><% end %></section></section></main>
