<% content_for :title, "Care Partner review · Goldenly" %>
<main class="care-partner-workspace"><%= render "care_partners/shared/sidebar" %><section class="care-partner-content"><header class="care-partner-page-heading"><p class="eyebrow">HUMAN MODERATION</p><h1>Care Partner review queue</h1><p>AI assistance may flag completeness or expiry concerns. A named Goldenly reviewer makes every decision.</p></header><section class="care-partner-panel"><div class="care-partner-panel-heading"><div><p class="eyebrow">APPLICATIONS</p><h2>Awaiting action</h2></div><%= link_to "Manual payouts →", moderation_earnings_path %></div><% @applications.each do |account| %><%= link_to moderation_care_partner_application_path(account), class: "moderation-row" do %><div class="avatar small"><%= (account.profile&.display_name || account.user.full_name).first %></div><div><strong><%= account.profile&.display_name || account.user.full_name %></strong><small><%= account.profile&.country || "Country not supplied" %> · submitted <%= account.submitted_at&.to_date&.to_fs(:long) || "draft" %></small></div><span class="status-pill <%= account.under_review? ? 'blue' : '' %>"><%= account.application_status.humanize %></span><b>→</b><% end %><% end %><% if @applications.empty? %><p class="empty-state">There are no Care Partner applications awaiting review.</p><% end %></section></section></main>
