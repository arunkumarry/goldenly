<% content_for :title, "Review Care Partner · Goldenly" %>
<main class="care-partner-workspace"><%= render "care_partners/shared/sidebar" %><section class="care-partner-content"><%= link_to "← Review queue", moderation_care_partner_applications_path, class: "back-link" %><header class="care-partner-page-heading"><p class="eyebrow">HUMAN REVIEW</p><h1><%= @account.profile&.display_name || @account.user.full_name %></h1><p><%= @account.profile&.country %> · <%= @account.application_status.humanize %>. Review original evidence before making a decision.</p></header><div class="moderation-grid"><section class="care-partner-panel"><p class="eyebrow">APPLICATION</p><h2>Submitted details</h2><dl class="review-details"><div><dt>Legal name</dt><dd><%= @account.profile&.legal_name || "—" %></dd></div><div><dt>Email</dt><dd><%= @account.user.email_address || "—" %></dd></div><div><dt>Phone</dt><dd><%= @account.user.phone_number || "—" %></dd></div><div><dt>Languages</dt><dd><%= @account.profile&.languages&.to_sentence || "—" %></dd></div><div><dt>Experience</dt><dd><%= @account.profile&.experience_summary || "—" %></dd></div><div><dt>Introduction video</dt><dd><%= @account.profile&.introduction_video_url.present? ? link_to("Open secure link", @account.profile.introduction_video_url, target: "_blank", rel: "noreferrer") : "—" %></dd></div></dl><h3>Identity evidence</h3><% @account.verification_documents.each do |document| %><article class="review-evidence"><div><strong><%= document.document_type %></strong><small><%= document.redacted_reference.presence || "No reference supplied" %> · expires <%= document.expires_on || "not supplied" %></small></div><%= link_to "View", document.file_reference, target: "_blank", rel: "noreferrer" if document.file_reference.present? %></article><% end %><h3>Credentials</h3><% @account.credentials.each do |credential| %><article class="review-evidence"><div><strong><%= credential.credential_type %></strong><small><%= credential.service_catalog&.name || "General" %> · <%= credential.issuer %> · expires <%= credential.expires_on || "not supplied" %></small></div><%= link_to "View", credential.file_reference, target: "_blank", rel: "noreferrer" if credential.file_reference.present? %></article><% end %><h3>Selected services</h3><% @account.care_partner_services.each do |service| %><article class="review-evidence"><div><strong><%= service.service_catalog.name %></strong><small><%= service.status.humanize %> · <%= service.service_catalog.clinical? ? "Clinical" : "Non-clinical" %></small></div></article><% end %></section><section class="care-partner-form-card"><p class="eyebrow">RECORD DECISION</p><h2>Human decision</h2><p>Approval must follow a review of the original evidence. The system will not use AI to approve, reject, suspend, or determine clinical eligibility.</p><%= form_with url: moderation_care_partner_application_path(@account), method: :patch, scope: :moderator_review, class: "care-partner-form" do |form| %><div class="care-partner-form-grid"><%= form.label :decision, "Decision" %><%= form.select :decision, [["Start review", "under_review"], ["Request changes", "changes_requested"], ["Approve and activate eligible services", "approved"], ["Reject", "rejected"], ["Suspend", "suspended"]], prompt: "Choose a human decision" %><%= form.label :reason, "Reason for applicant and audit trail" %><%= form.text_area :reason, rows: 5, required: true, placeholder: "Be clear about evidence reviewed, requested changes, or the decision basis." %><%= form.label :requested_sections, "Sections that need changes" %><%= form.select :requested_sections, [["Identity document", "identity"], ["Credential", "credential"], ["Introduction video", "video"], ["Service zones", "service_zones"], ["Payout method", "payout"]], {}, multiple: true %></div><div class="review-status-controls"><p><strong>Document verification</strong></p><% @account.verification_documents.each do |document| %><label><%= document.document_type %><%= select_tag "document_statuses[#{document.id}]", options_for_select(CarePartnerVerificationDocument.verification_statuses.keys.map { |status| [status.humanize, status] }, document.verification_status) %></label><% end %><p><strong>Credential verification</strong></p><% @account.credentials.each do |credential| %><label><%= credential.credential_type %><%= select_tag "credential_statuses[#{credential.id}]", options_for_select(CarePartnerCredential.verification_statuses.keys.map { |status| [status.humanize, status] }, credential.verification_status) %></label><% end %></div><%= form.submit "Save human review", class: "primary-button" %><% end %></section></div><section class="care-partner-panel review-history"><p class="eyebrow">AUDIT HISTORY</p><h2>Previous review decisions</h2><% @reviews.each do |review| %><article><div><strong><%= review.decision.humanize %></strong><small><%= review.reviewer.full_name %> · <%= review.created_at.to_fs(:long) %></small></div><p><%= review.reason %></p></article><% end %><% if @reviews.empty? %><p class="empty-state">No decisions have been recorded.</p><% end %></section></section></main>
