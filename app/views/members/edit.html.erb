<% content_for :title, "Edit member profile · Goldenly" %>
<main class="dashboard"><%= render "shared/sidebar" %><section class="content"><div class="workflow-page">
  <%= link_to "← Back to dashboard", root_path, class: "back-link" %>
  <section class="workflow-card">
    <p class="eyebrow">MEMBER PROFILE</p>
    <h1>Keep your details up to date</h1>
    <p class="workflow-intro">These details help your trusted circle coordinate care safely.</p>
    <%= render "shared/member_switcher", label: "Choose a member to view" %>
    <%= render "shared/errors", record: @member %>
    <%= form_with model: @member, url: member_path, class: "workflow-form" do |form| %>
      <div class="form-grid">
        <%= form.label :full_name %><%= form.text_field :full_name, required: true %>
        <%= form.label :phone_number, "Phone number" %><%= form.telephone_field :phone_number %>
        <%= form.label :preferred_language, "Preferred language" %><%= form.text_field :preferred_language, required: true %>
        <%= form.label :country %><%= form.text_field :country, placeholder: "Country", required: true %>
        <%= form.label :location, "City, state, or region" %><%= form.text_field :location, placeholder: "e.g. Toronto, Ontario" %>
        <%= form.label :mobility_needs, "Mobility or access needs" %><%= form.text_field :mobility_needs %>
        <%= form.label :emergency_contact_name, "Emergency contact name" %><%= form.text_field :emergency_contact_name %>
        <%= form.label :emergency_contact_phone, "Emergency contact phone" %><%= form.telephone_field :emergency_contact_phone %>
      </div>
      <%= form.submit "Save profile", class: "primary-button" %>
    <% end %>
  </section>
</div></section></main>
