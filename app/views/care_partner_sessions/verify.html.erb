<% content_for :title, "Verify Care Partner sign in · Goldenly" %>
<main class="auth-page care-partner-auth-page"><section class="workflow-card auth-card care-partner-auth-card">
  <%= link_to provider_platform_path, class: "brand" do %><%= image_tag "goldenly-logo.png", class: "brand-logo", alt: "" %><span>Goldenly</span><% end %>
  <p class="eyebrow">VERIFY CARE PARTNER ACCESS</p><h1>Enter your code</h1>
  <p class="workflow-intro">Enter the code sent to <strong><%= session[:pending_care_partner_identifier] %></strong>. This opens only the Care Partner workspace.</p>
  <%= form_with url: verify_care_partner_session_path, class: "workflow-form" do |form| %><div class="form-grid">
    <%= form.label :code, "Verification code" %><%= form.text_field :code, inputmode: "numeric", autocomplete: "one-time-code", required: true %>
  </div><%= form.submit "Verify Care Partner sign in", class: "primary-button" %><% end %>
  <p class="auth-switch"><%= link_to "Use a different Care Partner email or phone number", new_care_partner_session_path %></p>
</section></main>
