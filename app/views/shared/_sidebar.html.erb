<aside class="sidebar" aria-label="Main navigation">
  <a class="brand" href="<%= root_path %>"><%= image_tag "goldenly-logo.png", class: "brand-logo", alt: "" %><span>Goldenly</span></a>
  <p class="brand-tagline">Care. Connect. Thrive.</p>
  <nav class="main-nav">
    <% navigation_items.each do |label, path, icon| %>
      <%= link_to path, class: "nav-link #{current_page?(path) ? 'active' : ''}" do %>
        <span aria-hidden="true"><%= icon %></span><%= label %>
      <% end %>
    <% end %>
  </nav>
  <% if current_care_profile %><%= render "shared/member_switcher", label: "Active care profile" %><% end %>
  <div class="sidebar-footer">
    <div class="avatar small"><%= current_user.full_name.first %></div>
    <div><strong><%= current_user.full_name %></strong><span>My account</span></div>
    <%= button_to "Sign out", session_path, method: :delete, class: "more-button" %>
  </div>
</aside>
