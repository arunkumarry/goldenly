# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore local environment files, but keep safe templates under version control.
/.env*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Expo / React Native generated files. Native projects are regenerated with
# `npx expo prebuild` from the tracked Expo configuration and JavaScript source.
/mobile/node_modules/
/mobile/.expo/
/mobile/.env*
!/mobile/.env.example
/mobile/dist/
/mobile/web-build/
/mobile/ios/
/mobile/android/

# Operating-system metadata.
.DS_Store

# Ignore key files for decrypting credentials and more.
/config/*.key
